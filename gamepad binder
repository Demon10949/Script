local function simulateCombo(combo, isPressed)
	if not combo or #combo == 0 then return end
	
	if isPressed then
		for i = 1, #combo do
			local target = combo[i]
			if tostring(target):match("KeyCode") then
				VirtualInputManager:SendKeyEvent(true, target, false, game)
			elseif tostring(target):match("UserInputType") then
				local mb = (target == Enum.UserInputType.MouseButton1 and 0) or (target == Enum.UserInputType.MouseButton2 and 1) or 2
				local cam = workspace.CurrentCamera
				VirtualInputManager:SendMouseButtonEvent(cam.ViewportSize.X/2, cam.ViewportSize.Y/2, mb, true, game, 1)
			end
			task.wait(0.01)
		end
	else
		for i = #combo, 1, -1 do
			local target = combo[i]
			if tostring(target):match("KeyCode") then
				VirtualInputManager:SendKeyEvent(false, target, false, game)
			elseif tostring(target):match("UserInputType") then
				local mb = (target == Enum.UserInputType.MouseButton1 and 0) or (target == Enum.UserInputType.MouseButton2 and 1) or 2
				local cam = workspace.CurrentCamera
				VirtualInputManager:SendMouseButtonEvent(cam.ViewportSize.X/2, cam.ViewportSize.Y/2, mb, false, game, 1)
			end
			task.wait(0.01)
		end
	end
end

UserInputService.InputBegan:Connect(function(input, processed)
	if processed then return end
	if input.UserInputType.Name:match("Gamepad") and keyBinds[input.KeyCode] then
		simulateCombo(keyBinds[input.KeyCode], true)
	end
end)

UserInputService.InputEnded:Connect(function(input, processed)
	if input.UserInputType.Name:match("Gamepad") and keyBinds[input.KeyCode] then
		simulateCombo(keyBinds[input.KeyCode], false)
	end
end)
