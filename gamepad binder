local function startCapture(button, isGamepad, callback)
	button.Text = "Enter"
	local connection
	connection = UserInputService.InputBegan:Connect(function(input)
	
		if input.UserInputType == Enum.UserInputType.MouseButton1 and not isGamepad then 

			task.wait(0.1)
		end
		
		local valid = false
		if isGamepad and input.UserInputType.Name:match("Gamepad") then
			valid = true
		elseif not isGamepad then
			if input.UserInputType == Enum.UserInputType.Keyboard or input.UserInputType.Name:match("MouseButton") then
				valid = true
			end
		end

		if valid then
			connection:Disconnect()
			button.Text = input.KeyCode ~= Enum.KeyCode.Unknown and input.KeyCode.Name or input.UserInputType.Name
			callback(input.KeyCode ~= Enum.KeyCode.Unknown and input.KeyCode or input.UserInputType)
		end
	end)
end

