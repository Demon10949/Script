local activeTimers = {}

local function capturePCCombo(button, callback)
	local buttonId = tostring(button)
	if activeTimers[buttonId] then
		activeTimers[buttonId] = false
	end
	activeTimers[buttonId] = true

	button.Text = "Listening (5s)"
	task.wait(0.15)

	local comboKeys = {}
	local duration = 5
	local startTime = os.clock()

	local connection
	connection = UserInputService.InputBegan:Connect(function(input)
		local isKeyboard = (input.UserInputType == Enum.UserInputType.Keyboard)
		local isMouse = input.UserInputType.Name:match("MouseButton")

		if isKeyboard or isMouse then
			local key = isKeyboard and input.KeyCode or input.UserInputType
			if key ~= Enum.KeyCode.Unknown and #comboKeys < 5 and not table.find(comboKeys, key) then
				table.insert(comboKeys, key)
			end
		end
	end)

	task.spawn(function()
		while os.clock() - startTime < duration and activeTimers[buttonId] do
			local timePassed = os.clock() - startTime
			local remaining = math.ceil(duration - timePassed)
			if remaining < 0 then remaining = 0 end

			if #comboKeys == 0 then
				button.Text = "Listening (" .. remaining .. "s)"
			else
				local names = {}
				for _, k in ipairs(comboKeys) do table.insert(names, k.Name) end
				button.Text = table.concat(names, " + ") .. " (" .. remaining .. "s)"
			end
			task.wait(0.05)
		end

		connection:Disconnect()

		if activeTimers[buttonId] then
			if #comboKeys == 0 then
				button.Text = "pckey"
				callback(nil)
			else
				local names = {}
				for _, k in ipairs(comboKeys) do table.insert(names, k.Name) end
				button.Text = table.concat(names, " + ")
				callback(comboKeys)
			end
			activeTimers[buttonId] = nil
		end
	end)
end

local function captureGamepadKey(button, callback)
	button.Text = "Press GP Key"
	task.wait(0.1)
	local connection
	connection = UserInputService.InputBegan:Connect(function(input)
		if input.UserInputType.Name:match("Gamepad") then
			connection:Disconnect()
			button.Text = input.KeyCode.Name
			callback(input.KeyCode)
		end
	end)
end

